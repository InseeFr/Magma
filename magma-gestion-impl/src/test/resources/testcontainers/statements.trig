        skos:prefLabel "Enquête"@fr ;
        skos:prefLabel "Survey"@en .

    <http://id.insee.fr/concepts/periodicity/A>
        skos:notation "A" ;
        skos:prefLabel "Annuelle"@fr ;
        skos:prefLabel "Annual"@en .

    <http://id.insee.fr/organisations/insee>
        rdf:type org:Organization ;
        dcterms:identifier "insee" ;
        skos:prefLabel "Institut national de la statistique"@fr ;
        skos:prefLabel "National Institute of Statistics"@en .

    <http://id.insee.fr/organisations/drees>
        rdf:type org:Organization ;
