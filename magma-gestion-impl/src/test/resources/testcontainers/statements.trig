<http://rdf.insee.fr/graphes/operations> {
    <http://id.insee.fr/operations/serie/s1001>
        rdf:type insee:StatisticalOperationSeries ;
        skos:prefLabel "Série de test"@fr ;
        skos:prefLabel "Test series"@en ;
        skos:altLabel "Série alt"@fr ;
        skos:altLabel "Alt series"@en ;
        dcterms:abstract "Résumé de la série"@fr ;
        dcterms:abstract "Series abstract"@en ;
        skos:historyNote "Note historique"@fr ;
        skos:historyNote "Historical note"@en ;
        dcterms:type <http://id.insee.fr/concepts/type/E> ;
        dcterms:accrualPeriodicity <http://id.insee.fr/concepts/periodicity/A> ;
        dcterms:created "2020-01-15" ;
        dcterms:modified "2024-06-01" ;
        insee:validationState "Publiée" ;
        dc:creator <http://id.insee.fr/organisations/insee> ;
        dcterms:publisher <http://id.insee.fr/organisations/drees> ;
        dcterms:contributor <http://id.insee.fr/organisations/dares> .

    <http://id.insee.fr/operations/famille/f1001>
        rdf:type insee:StatisticalOperationFamily ;
        dcterms:hasPart <http://id.insee.fr/operations/serie/s1001> ;
